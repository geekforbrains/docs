{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Operator",
  "colors": {
    "primary": "#B45309",
    "light": "#D97706",
    "dark": "#92400E"
  },
  "favicon": "/favicon.svg",
  "hero": {
    "title": "Agents have joined the chat.",
    "description": "Local Slack-connected agents with markdown prompts, file-backed memory, scheduled jobs, and real tools.",
    "image": {
      "href": "/images/operator_banner.png",
      "alt": "Operator - a monkey at the switchboard"
    },
    "actions": [
      {
        "label": "Get started",
        "href": "/quickstart"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/geekforbrains/operator",
        "variant": "outline"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Start Here",
            "pages": [
              "index",
              "quickstart",
              "transports/slack",
              "configuration"
            ]
          },
          {
            "group": "Customize",
            "pages": [
              "concepts/agents",
              "concepts/jobs",
              "concepts/skills",
              "concepts/memory",
              "concepts/models"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "concepts/tools",
              "concepts/users",
              "cli/overview",
              "cli/users",
              "cli/service",
              "cli/jobs",
              "cli/skills",
              "cli/memory"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/geekforbrains/operator",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/geekforbrains/operator"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/geekforbrains/operator"
    }
  }
}
