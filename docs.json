{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "🙊 Operator",
  "colors": {
    "primary": "#B45309",
    "light": "#D97706",
    "dark": "#92400E"
  },
  "favicon": "/favicon.svg",
  "hero": {
    "title": "Agents have joined the chat.",
    "description": "Deploy autonomous AI agents into your team's chat. Markdown-driven, team-native, model-agnostic.",
    "image": {
      "href": "/images/operator_banner.png",
      "alt": "Operator — a monkey at the switchboard"
    },
    "actions": [
      {
        "label": "Get started",
        "href": "/quickstart"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/geekforbrains/operator",
        "variant": "outline"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "configuration",
              "changelog"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/agents",
              "concepts/users",
              "concepts/jobs",
              "concepts/skills",
              "concepts/memory",
              "concepts/tools"
            ]
          },
          {
            "group": "Transports",
            "pages": [
              "transports/slack"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/users",
              "cli/service",
              "cli/jobs",
              "cli/skills",
              "cli/kv",
              "cli/memories"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/geekforbrains/operator",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/geekforbrains/operator"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/geekforbrains/operator"
    }
  }
}
